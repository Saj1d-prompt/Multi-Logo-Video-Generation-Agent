APP_NAME=Multi Brand Video Agent
APP_ENV=development
APP_PORT=8000

GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service_account.json
WORKSPACE_ROOT=/app/workspace

CLICKUP_API_TOKEN=replace_with_new_clickup_token
CLICKUP_API_BASE=https://api.clickup.com/api/v2

INTERNAL_API_KEY=replace_with_a_long_random_value

DEFAULT_LOGO_POSITION=top_right
DEFAULT_LOGO_WIDTH_PERCENT=15
DEFAULT_MARGIN_X=40
DEFAULT_MARGIN_Y=40
DEFAULT_BGM_VOLUME=0.08

OUTPUT_EXISTING_POLICY=skip